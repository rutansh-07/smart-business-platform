# Copy to backend/.env and fill in your values
PORT=5000

# Get this from MongoDB Atlas → Connect → Drivers → Node.js
# Use "Connect your application" and replace <password> with your DB user password
MONGO_URI=mongodb://localhost:27017/smart-business-platform

JWT_SECRET=replace_with_a_long_random_secret_key

# Set to "production" only when deploying (Render/Railway set this automatically)
# NODE_ENV=production
